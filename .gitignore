# ═══════════════════════════════════════════════
#              OSZILLOR — .gitignore
# ═══════════════════════════════════════════════

# ── Foundry ──
contracts/cache/
contracts/out/
contracts/broadcast/*/31337/
contracts/broadcast/**/dry-run/
contracts/lib/

# ── Dependencies ──
node_modules/
.pnp/
.pnp.js

# ── Build outputs ──
dist/
build/
out/
.next/
.nuxt/

# ── Environment ──
.env
.env.*
.env.local
.env.*.local

# ── Secrets & keys ──
*.pem
*.key
*.p12
secrets/
credentials/
keystore/
wallet.json

# ── Internal / Private ──
plan.md
progress/
.references/
.serena/
.claude/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*.sw?
*.suo

# ── TypeScript ──
*.tsbuildinfo

# ── Cache ──
.cache/
.turbo/
.eslintcache

# ── Coverage ──
coverage/
.nyc_output/

# ── Temp ──
tmp/
temp/
*.tmp
*.bak

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
